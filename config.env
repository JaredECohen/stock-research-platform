# =============================================================================
# MarketMosaic — Committed runtime config
# =============================================================================
# This file is in git. It holds the model assignments, feature flags, and
# tuning knobs that should be the same for every contributor / deployment by
# default. Production secrets (API keys, database URL, etc.) live in `.env`
# (gitignored — copy from `example.env`).
#
# Load order (defined in `backend/app/config.py::_project_env_files`):
#     1. config.env   ← this file: committed defaults
#     2. .env         ← gitignored: secrets + per-deployment overrides
#     3. process env  ← export FOO=bar wins over both
#
# So an OPENAI_PM_MODEL set in `.env` overrides the value here without
# changing this file. Use that for one-off experiments. Use a PR to this
# file when you're committing a model decision the whole team should run.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. PER-AGENT MODEL ASSIGNMENT
# -----------------------------------------------------------------------------
# Each agent has its own model knob. The architecture spec assigns the PM the
# strongest model and pushes the bulk of the work onto cheaper sector + tool
# agents. The critic deliberately runs on a different family (Anthropic Opus)
# so it argues independently. News + social use Gemini Flash + Search
# grounding; long-doc analysts (filing / earnings) have a Gemini override
# documented for future use.
# -----------------------------------------------------------------------------

# Generic strong/cheap routing — fallback when no per-agent model is set
# and for the intent classifier. Strong is for synthesis/critic; cheap is
# for extraction/classification.
OPENAI_STRONG_MODEL=gpt-5.5
OPENAI_CHEAP_MODEL=gpt-4.1-mini

# Per-agent OpenAI overrides (Phase 3 multi-agent assignment).
#
# Note on PM: the architecture spec lists `gpt-5.5-pro`, but as of
# 2026-05-02 that model is Responses-API only (`/v1/responses`) and our
# wrapper currently uses Chat Completions. We use `gpt-5.5` for the PM
# instead — same family, chat-compatible, still the strongest chat model
# in the GPT-5 lineup. Wiring a Responses-API path is tracked as a Wave 6
# follow-up; once that lands, flip this back to `gpt-5.5-pro`.
OPENAI_PM_MODEL=gpt-5.5
OPENAI_SECTOR_MODEL=gpt-5.4
OPENAI_TOOL_MODEL=gpt-5.4
OPENAI_MACRO_MODEL=gpt-5.4

# Anthropic — strong/cheap defaults + critic-specific override.
ANTHROPIC_STRONG_MODEL=claude-opus-4-8
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_CRITIC_MODEL=claude-opus-4-8

# Gemini — news, social, optional long-doc analyst override.
GEMINI_NEWS_MODEL=gemini-2.5-flash
GEMINI_SOCIAL_MODEL=gemini-2.5-flash
GEMINI_LONGDOC_MODEL=gemini-3.1-pro

# Vertex AI override (optional). When VERTEX_PROJECT_ID is set in `.env`,
# all Gemini calls route through Vertex. If VERTEX_MODEL is also set here,
# it overrides the per-agent GEMINI_*_MODEL envs above for every Gemini
# call on the Vertex backend. Leave empty to let each agent use its own
# Gemini model name on Vertex.
#
# Note: as of 2026-05-02, `gemini-3.1-pro` is on the direct Gemini API
# but NOT yet a Vertex publisher model. The strongest equivalent on
# Vertex is `gemini-2.5-pro` (a thinking model — needs ≥200 max_output_tokens
# headroom; the long-doc analyst budget already covers this). Verified
# against `ieor-4576-jared` project on us-central1.
VERTEX_PROJECT_ID=ieor-4576-jared
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro


# -----------------------------------------------------------------------------
# 2. FEATURE FLAGS
# -----------------------------------------------------------------------------

# Forces demo data even if live keys are configured. Useful for development
# and deterministic testing.
USE_DEMO_DATA=true

# Allows live providers to attempt fetches (with fallback to demo on failure).
# When false, live providers are bypassed entirely.
#
# Production default = true: the data_service tries FMP / AV / FRED / SEC etc.
# first and silently falls through to the demo dataset if a provider fails or
# isn't configured. Tests force this back to false in `conftest.py` so test
# runs stay deterministic and zero-cost regardless of which keys are present
# in `.env`.
ENABLE_LIVE_DATA=true

# Risk-committee critic loop. Disable for faster memos at the cost of weaker
# risk framing on the resulting memo.
ENABLE_AGENT_CRITIC=true

# Embedding-based retrieval (requires OPENAI_API_KEY). Default = BM25.
ENABLE_VECTOR_SEARCH=false

# Route single_stock_analysis through the OpenAI Agents SDK runtime.
# Default false → deterministic legacy graph. When true + OPENAI_API_KEY is
# set, real agents.Runner exercises real handoffs / tool calls.
USE_AGENTS_SDK=true

# Always-on monitoring loops (EDGAR / news / social / macro). Default false
# in dev/test; true in prod where you want auto-refreshes on filings.
ENABLE_MONITORING=false

# Long-term agent memory. Reflection writes only fire on delta events
# (new earnings / filing / material news), so leaving on is cheap.
ENABLE_LONG_TERM_MEMORY=true

# Wave 3C: drill-down "long-form" reports per agent. Adds ~$0.02-0.04 of
# token spend per memo for richer markdown bodies in the per-tile drawer.
# Default-on (MASTER_PLAN §6 locked decision); flip off if smoke runtime
# spikes or you want zero token spend on memos.
ENABLE_LONG_FORM_REPORTS=true

# Wave 9: PM↔specialist deep-research dialog. After the parallel fan-out,
# the PM critiques each specialist's finding and asks 0-3 follow-up
# questions tagged with which specialist should answer; targeted agents
# re-fire with the question prepended to their prompt. Loop exits when
# PM declares "no further questions" or the budget is exhausted.
#
# Cost: each enabled run adds ~$0.01-0.05 in tokens (one PM critique
# call per round + one re-fire per question). Skipped on backtests.
# Tune via DEEP_RESEARCH_MAX_ROUNDS / _MAX_QUESTIONS_PER_ROUND below.
ENABLE_DEEP_RESEARCH=true
DEEP_RESEARCH_MAX_ROUNDS=3
DEEP_RESEARCH_MAX_QUESTIONS_PER_ROUND=3

# PM rating blend (Option A). Final rating_label is derived from
# `w * llm_score + (1 - w) * factor_pm_score`, where llm_score is the
# bucket center of the PM LLM's rating call (Very Bullish=90 … Very
# Bearish=10). 0.0 → factor blend wins outright (legacy Wave 8P);
# 1.0 → LLM rating wins outright. 0.4 = financials-led with a real
# voice for qualitative judgment. Tune up if you trust the PM's
# narrative more than the deterministic factors.
LLM_RATING_WEIGHT=0.4


# -----------------------------------------------------------------------------
# 3. MEMORY CONFIGURATION
# -----------------------------------------------------------------------------

# Filesystem path for company + sector memory notebooks.
MEMORY_DIR=./memory
# Cap before older entries fold into a condensed historical-context block.
MEMORY_MAX_ENTRIES=50
# How many oldest entries fold per condensation pass.
MEMORY_CONDENSE_BATCH=10


# -----------------------------------------------------------------------------
# 4. RUNTIME LIMITS / TUNING
# -----------------------------------------------------------------------------

# Generic provider-call cache TTL (provider helpers, not the snapshot store).
CACHE_TTL_SECONDS=3600
# Maximum prompt-context bytes per agent call.
MAX_AGENT_CONTEXT_CHARS=60000
# Max holdings the portfolio builder will return.
MAX_STOCKS_IN_PORTFOLIO=25
# Universe key the screener defaults to when no theme is requested.
DEFAULT_STOCK_UNIVERSE=large_cap_demo
