# =============================================================================
# MarketMosaic — example environment configuration
# Copy to `.env` (or `backend/.env`) and fill in keys you have.
#
# The app runs in demo mode with ZERO keys. Live data + LLM-backed agents
# turn on only when their respective keys are present, so you can ramp up
# gradually.
#
# Each section below documents what the key is used for in MarketMosaic
# specifically and notes whether it's required, optional-but-useful, or
# defined-but-not-yet-wired.
# =============================================================================


# =============================================================================
# 1. LLM PROVIDERS
# =============================================================================
# MarketMosaic is a multi-agent system. Different agents use different
# providers — this is intentional cross-family bias to mitigate single-
# model hallucination on investment recommendations.
#
# Provider routing for the orchestrator is controlled by LLM_PROVIDER:
#   - "auto"      : use Anthropic if its key is set, else OpenAI (default)
#   - "anthropic" : force Anthropic everywhere (requires ANTHROPIC_API_KEY)
#   - "openai"    : force OpenAI everywhere (requires OPENAI_API_KEY)
#
# Specialized agents (news, social, critic) override this via
# `provider_override=` regardless of LLM_PROVIDER, so you can run
# anthropic=critic + openai=PM + gemini=news/social all at once.
# =============================================================================

LLM_PROVIDER=auto


# -----------------------------------------------------------------------------
# OpenAI — used by: PM Orchestrator, Sector agents, Tool agents (filing /
# earnings / valuation / comps / risk), Macro agent, intent classifier,
# and as the default fallback for everything else.
#
# WITHOUT this key: the platform still runs but every LLM-backed agent
# falls through to a deterministic stub that produces structured output
# from cohort math + provider data. Memos still render; rationale prose
# is shorter and less nuanced.
#
# Get a key: https://platform.openai.com/api-keys  (paid)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# Strong/cheap routing — used by `llm.chat_json(..., route="strong"|"cheap")`.
# Strong is for synthesis/critic; cheap is for extraction/classification.
OPENAI_STRONG_MODEL=gpt-5.5
OPENAI_CHEAP_MODEL=gpt-4.1-mini

# Per-agent model overrides (Phase 3 multi-agent assignment). PM gets the
# strongest model; sector + tool agents share GPT-5.4. Edit these to
# swap models per agent without touching code.
OPENAI_PM_MODEL=gpt-5.5-pro
OPENAI_SECTOR_MODEL=gpt-5.4
OPENAI_TOOL_MODEL=gpt-5.4
OPENAI_MACRO_MODEL=gpt-5.4


# -----------------------------------------------------------------------------
# Anthropic — used by: Critic / Risk Committee (cross-family by design),
# and as a fallback PM when LLM_PROVIDER=anthropic.
#
# WITHOUT this key: the critic uses OpenAI (or the rule-based stub if
# OPENAI_API_KEY is also empty). You lose the cross-family bias, but
# the critic still runs.
#
# Get a key: https://console.anthropic.com/settings/keys  (paid)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=

ANTHROPIC_STRONG_MODEL=claude-opus-4-7
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5

# Critic agent. Default is Opus 4.7 (deliberately a different family from
# the PM/sector OpenAI models so it argues independently).
ANTHROPIC_CRITIC_MODEL=claude-opus-4-7


# -----------------------------------------------------------------------------
# Google Gemini — used by: News agent (with Google Search grounding),
# Social-sentiment agent, and as an optional override for long-doc
# analysts (filing + earnings) which have larger inputs.
#
# WITHOUT this key: news_agent falls back to news_service (Alpha Vantage
# or demo); social_agent falls back to a deterministic sentiment stub;
# filing/earnings agents stay on OpenAI/Anthropic.
#
# Get a key: https://aistudio.google.com/app/apikey  (paid; generous free tier)
# -----------------------------------------------------------------------------

GEMINI_API_KEY=

GEMINI_NEWS_MODEL=gemini-2.5-flash
GEMINI_SOCIAL_MODEL=gemini-2.5-flash
# Long-doc analyst override (filing + earnings) when Gemini key is present.
GEMINI_LONGDOC_MODEL=gemini-3.1-pro


# =============================================================================
# 2. MARKET DATA + FUNDAMENTALS PROVIDERS
# =============================================================================
# All optional. Without any of these, MarketMosaic uses its built-in demo
# dataset (28+ large-cap names with 4 years of statements, transcripts,
# filings, news, and 13 macro series).
# =============================================================================


# -----------------------------------------------------------------------------
# Financial Modeling Prep (FMP) — PRIMARY fundamentals provider.
# Used for: company profiles, income statements, balance sheets, cash
# flows, ratios, earnings, key metrics, and as the default price source.
# This is the highest-leverage key — most "live mode" data goes through FMP.
#
# Get a key: https://site.financialmodelingprep.com/developer/docs  (free tier; paid tiers unlock more endpoints + history)
# -----------------------------------------------------------------------------

FMP_API_KEY=


# -----------------------------------------------------------------------------
# Alpha Vantage — used for: earnings call TRANSCRIPTS and news/sentiment
# (the news_agent's deterministic fallback when GEMINI_API_KEY is empty).
# Transcripts are the only public source MarketMosaic supports today, so
# this key is the unlock for the earnings-call analyst on live data.
#
# Get a key: https://www.alphavantage.co/support/#api-key  (free tier; rate-limited)
# -----------------------------------------------------------------------------

ALPHA_VANTAGE_API_KEY=


# -----------------------------------------------------------------------------
# FRED (St. Louis Fed) — used for: macro time series (fed funds, CPI, 2y/10y
# yields, unemployment, oil, HY spreads, etc.). The hourly macro_loop
# polls FRED to refresh the MacroBroadcast that sector agents subscribe to.
#
# FREE forever. No reason not to add this one — single biggest "free
# upgrade" from demo mode.
#
# Get a key: https://fred.stlouisfed.org/docs/api/api_key.html  (free)
# -----------------------------------------------------------------------------

FRED_API_KEY=


# -----------------------------------------------------------------------------
# SEC EDGAR — used for: 10-K / 10-Q / 8-K filings (text + accession numbers).
# The edgar_poller monitoring loop watches for new accessions and
# invalidates cached company data when one lands.
#
# NO API KEY — SEC requires only a valid User-Agent string identifying you
# (an email) for compliance. Always-on; this is wired and used today.
#
# Spec: https://www.sec.gov/os/accessing-edgar-data
# -----------------------------------------------------------------------------

SEC_USER_AGENT=MarketMosaic your-email@example.com


# -----------------------------------------------------------------------------
# Polygon.io — used for: prices (alternative to FMP) and news.
# OPTIONAL — if FMP_API_KEY is set, MarketMosaic prefers FMP for prices.
# Polygon is only consulted when FMP fails or returns empty.
#
# Get a key: https://polygon.io/dashboard/api-keys  (free tier; paid for live realtime)
# -----------------------------------------------------------------------------

POLYGON_API_KEY=


# -----------------------------------------------------------------------------
# Tiingo — used for: prices (alternative to FMP / Polygon).
# OPTIONAL — same role as Polygon; tried as a fallback if both FMP and
# Polygon fail or return empty.
#
# Get a key: https://www.tiingo.com/account/api/token  (free tier)
# -----------------------------------------------------------------------------

TIINGO_API_KEY=


# -----------------------------------------------------------------------------
# Finnhub — DEFINED BUT NOT YET WIRED.
# Reserved for an alt-fundamentals / alt-news source. The provider class
# exists in code but the data_service capability chain doesn't route to
# it yet. Setting this key today has no effect.
#
# https://finnhub.io/dashboard
# -----------------------------------------------------------------------------

FINNHUB_API_KEY=


# -----------------------------------------------------------------------------
# Intrinio — DEFINED BUT NOT YET WIRED.
# Reserved for premium fundamentals / institutional data. Provider stub
# exists; not on any capability chain. Setting this key today has no
# effect.
#
# https://intrinio.com/
# -----------------------------------------------------------------------------

INTRINIO_API_KEY=


# -----------------------------------------------------------------------------
# Nasdaq Data Link (formerly Quandl) — DEFINED BUT NOT YET WIRED.
# Reserved for alt-data ingestion. Provider stub exists; not on any
# capability chain. Setting this key today has no effect.
#
# https://data.nasdaq.com/account/profile
# -----------------------------------------------------------------------------

NASDAQ_DATA_LINK_API_KEY=


# =============================================================================
# 3. FEATURE FLAGS
# =============================================================================

# USE_DEMO_DATA=true forces demo mode even if live keys are present.
# Useful for development / deterministic testing.
USE_DEMO_DATA=true

# ENABLE_LIVE_DATA=true allows providers to attempt live fetches (with
# fallback to demo on failure). When false, live providers are bypassed
# entirely and demo data is the source of truth.
ENABLE_LIVE_DATA=false

# ENABLE_AGENT_CRITIC enables the risk-committee critic loop. Disable for
# faster memos at the cost of weaker risk framing.
ENABLE_AGENT_CRITIC=true

# ENABLE_VECTOR_SEARCH uses embeddings for retrieval (requires
# OPENAI_API_KEY). Default false → BM25 retrieval is fast and key-free.
ENABLE_VECTOR_SEARCH=false

# Route single_stock_analysis through the OpenAI Agents SDK runtime
# (Phase 3). Default false keeps the deterministic legacy graph in
# charge. The SDK runtime topology is hub-and-spokes: PM at hub,
# sector spokes, tool sub-agents.
USE_AGENTS_SDK=false

# Always-on monitoring loops (EDGAR poller, news, social, macro).
# Default false in dev/test; flip to true in prod where you want
# automatic memo refreshes on filings + macro broadcasts.
ENABLE_MONITORING=false

# Long-term agent memory (filesystem markdown notebooks per company +
# per sector). Default true — the reflection agent only writes to
# memory when a delta event fires (new earnings / filing / material
# news), so this is cheap to leave on. Disable for fully ephemeral runs.
ENABLE_LONG_TERM_MEMORY=true

# Memory storage path + bounds. Memory is per-deployment runtime state,
# not source — files live under <MEMORY_DIR>/{companies,sectors}/.
MEMORY_DIR=./memory
MEMORY_MAX_ENTRIES=50
MEMORY_CONDENSE_BATCH=10


# =============================================================================
# 4. DATABASE
# =============================================================================
# Default = SQLite (zero-config local). Switch to Postgres in production
# by setting DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db
# =============================================================================

DATABASE_URL=sqlite:///./marketmosaic.db
POSTGRES_USER=marketmosaic
POSTGRES_PASSWORD=marketmosaic
POSTGRES_DB=marketmosaic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


# =============================================================================
# 5. APP / SERVER
# =============================================================================

APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# =============================================================================
# 6. RUNTIME LIMITS / TUNING
# =============================================================================

CACHE_TTL_SECONDS=3600
MAX_AGENT_CONTEXT_CHARS=60000
MAX_STOCKS_IN_PORTFOLIO=25
DEFAULT_STOCK_UNIVERSE=large_cap_demo
