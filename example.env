# =============================================================================
# MarketMosaic — Secrets template
# =============================================================================
# Copy this file to `.env` (or `backend/.env`) and fill in your keys.
# `.env` is gitignored — it should never be committed.
#
# Non-secret config (model assignments, feature flags, runtime tuning) lives
# in `config.env` (committed, in git). Settings loads `config.env` first,
# then `.env` (so anything you put here overrides the committed defaults).
#
# Load order:
#     1. config.env   ← committed defaults (model knobs, feature flags)
#     2. .env         ← this file copied + filled: secrets + per-deployment
#     3. process env  ← export VAR=value wins over both
#
# Every key below is OPTIONAL. The app runs in demo mode with zero keys.
# Each section documents what the key is used for and what happens without it.
# =============================================================================


# =============================================================================
# 1. LLM PROVIDER ROUTING
# =============================================================================
# How to pick between OpenAI / Anthropic when both are configured.
#   - "auto"      : Anthropic if its key is set, else OpenAI (default)
#   - "anthropic" : force Anthropic
#   - "openai"    : force OpenAI
#   - "vertex"    : documentation/intent value when running Gemini via
#                   Vertex AI (see section 2). Doesn't change orchestrator
#                   routing — Vertex backend is selected by VERTEX_PROJECT_ID
#                   regardless. Accepted so existing GCP-pattern .env files
#                   import cleanly.
# Specialized agents (critic via Anthropic, news/social via Gemini) override
# this regardless via per-call provider_override.

LLM_PROVIDER=auto


# =============================================================================
# 2. LLM API KEYS
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI — used by: PM Orchestrator, Sector agents, Tool agents (filing /
# earnings / valuation / comps / risk), Macro agent, intent classifier.
#
# WITHOUT this key: every LLM-backed agent falls through to a deterministic
# stub. Memos still render; rationale prose is shorter and less nuanced.
#
# Get a key: https://platform.openai.com/api-keys  (paid)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic — used by: Critic / Risk Committee (cross-family by design).
#
# WITHOUT this key: critic uses OpenAI (or rule-based stub if both empty).
# You lose the cross-family bias mitigation but the critic still runs.
#
# Get a key: https://console.anthropic.com/settings/keys  (paid)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google Gemini — used by: News agent (with Google Search grounding),
# Social-sentiment agent, optional long-doc analyst override.
#
# WITHOUT this key: news_agent falls back to news_service (Alpha Vantage
# or demo); social_agent falls back to a deterministic sentiment stub.
#
# Get a key: https://aistudio.google.com/app/apikey  (paid; generous free tier)
# -----------------------------------------------------------------------------

GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Google Vertex AI — alternative Gemini access path.
# Use Vertex when you have a Google Cloud project with the Vertex AI API
# enabled and you'd rather authenticate via Application Default Credentials
# (gcloud / service-account) than a raw API key.
#
# When VERTEX_PROJECT_ID is set, the Gemini client constructs as
# `genai.Client(vertexai=True, project=..., location=...)` and Vertex wins
# over GEMINI_API_KEY. Auth flow:
#
#     gcloud auth application-default login
#     # OR set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
#
# `LLM_PROVIDER=vertex` is accepted as a documentation/intent value
# alongside auto/openai/anthropic — it doesn't change orchestrator routing
# but signals the deployment is using Vertex for Gemini calls.
# -----------------------------------------------------------------------------

VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1


# =============================================================================
# 3. MARKET DATA + FUNDAMENTALS PROVIDERS
# =============================================================================
# All optional. Without any of these, MarketMosaic uses its built-in demo
# dataset (33+ large-cap names with 4 years of statements, transcripts,
# filings, news, and 13 macro series).
# =============================================================================

# -----------------------------------------------------------------------------
# Financial Modeling Prep (FMP) — PRIMARY fundamentals provider.
# Used for: profiles, income statements, balance sheets, cash flows,
# ratios, earnings, key metrics, default price source.
# Highest-leverage data key — most "live mode" data goes through FMP.
#
# Get a key: https://site.financialmodelingprep.com/developer/docs  (free tier)
# -----------------------------------------------------------------------------

FMP_API_KEY=

# -----------------------------------------------------------------------------
# Alpha Vantage — earnings call TRANSCRIPTS (the only public source MM
# supports today) and news/sentiment fallback when no Gemini key.
#
# Get a key: https://www.alphavantage.co/support/#api-key  (free tier; rate-limited)
# -----------------------------------------------------------------------------

ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# FRED (St. Louis Fed) — macro time series. Powers the hourly macro_loop
# that broadcasts MacroBroadcast to sector agents. FREE forever; biggest
# free upgrade from demo mode.
#
# Get a key: https://fred.stlouisfed.org/docs/api/api_key.html  (free)
# -----------------------------------------------------------------------------

FRED_API_KEY=

# -----------------------------------------------------------------------------
# SEC EDGAR — 10-K / 10-Q / 8-K filings.
# NO API KEY — SEC requires only a valid User-Agent (your email) for
# compliance. The edgar_poller monitoring loop needs this set.
#
# Spec: https://www.sec.gov/os/accessing-edgar-data
# -----------------------------------------------------------------------------

SEC_USER_AGENT=MarketMosaic your-email@example.com

# -----------------------------------------------------------------------------
# Polygon.io — alternative price source. Only consulted when FMP fails.
# Get a key: https://polygon.io/dashboard/api-keys  (free tier)
# -----------------------------------------------------------------------------

POLYGON_API_KEY=

# -----------------------------------------------------------------------------
# Tiingo — second alternative price source (after FMP + Polygon).
# Get a key: https://www.tiingo.com/account/api/token  (free tier)
# -----------------------------------------------------------------------------

TIINGO_API_KEY=

# -----------------------------------------------------------------------------
# Finnhub / Intrinio / Nasdaq Data Link — DEFINED BUT NOT YET WIRED.
# Provider classes exist; not on any data_service capability chain.
# Setting these today has no effect.
# -----------------------------------------------------------------------------

FINNHUB_API_KEY=
INTRINIO_API_KEY=
NASDAQ_DATA_LINK_API_KEY=

# -----------------------------------------------------------------------------
# EIA (US Energy Information Administration) — petroleum + natural gas
# storage snapshots, WTI / Henry Hub spot prices, monthly electricity.
# Used by the sector analyst for energy + utilities + chemicals overlays.
#
# WITHOUT this key the provider falls back to the public EIA endpoints
# (legacy XLS storage workbooks + daily spot price downloads). With the
# key it uses the keyed API v2 which is faster, JSON, and rate-uncapped.
#
# Get a key: https://www.eia.gov/opendata/register.php  (free)
# -----------------------------------------------------------------------------

EIA_API_KEY=

# -----------------------------------------------------------------------------
# BLS (Bureau of Labor Statistics) — CPI components (food, vehicles,
# gasoline, medical, shelter) and industry / state-level employment.
# Used by the sector analyst for inflation pricing-power + labor-cost
# overlays.
#
# WITHOUT this key the public endpoint caps you to ~25 requests per day
# per IP. With a (free) registration key the cap rises to 500/day.
#
# Get a key: https://data.bls.gov/registrationEngine/  (free)
# -----------------------------------------------------------------------------

BLS_API_KEY=

# -----------------------------------------------------------------------------
# Census Bureau — Monthly Advance Retail Trade Survey (MARTS), residential
# + nonresidential construction put-in-place, building permits by state.
# Used by the sector analyst for consumer + REIT + homebuilder overlays.
#
# WITHOUT this key the public endpoint serves all of MARTS / C30 but with
# rate limits. The key lifts those limits.
#
# Get a key: https://api.census.gov/data/key_signup.html  (free)
# -----------------------------------------------------------------------------

CENSUS_API_KEY=


# =============================================================================
# 4. DATABASE
# =============================================================================
# Default SQLite (zero-config local). For Postgres set:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db

DATABASE_URL=sqlite:///./marketmosaic.db
POSTGRES_USER=marketmosaic
POSTGRES_PASSWORD=marketmosaic
POSTGRES_DB=marketmosaic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


# =============================================================================
# 5. APP / SERVER
# =============================================================================

APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
