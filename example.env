# =============================================================================
# MarketMosaic — example environment configuration
# Copy to `.env` (or `backend/.env`) and fill in keys you have. The app runs
# in demo mode without any keys at all.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM CONFIGURATION
# MarketMosaic supports both OpenAI and Anthropic. With at least one key set,
# agents call the corresponding provider; without any key, agents fall back to
# deterministic, rule-based "demo agents" that still produce structured output.
#
# LLM_PROVIDER selects routing:
#   - "auto"      : use Anthropic if its key is set, else OpenAI (default)
#   - "anthropic" : force Anthropic (requires ANTHROPIC_API_KEY)
#   - "openai"    : force OpenAI (requires OPENAI_API_KEY)
# -----------------------------------------------------------------------------
LLM_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
# Strong model used for PM synthesis, critic, and complex reasoning
OPENAI_STRONG_MODEL=gpt-5.5
# Cheap model used for extraction, summarization, classification
OPENAI_CHEAP_MODEL=gpt-4.1-mini
# Per-role models used by the Agents SDK runtime (Phase 3).
OPENAI_PM_MODEL=gpt-5.5-pro
OPENAI_SECTOR_MODEL=gpt-5.4
OPENAI_TOOL_MODEL=gpt-5.4

# Anthropic
ANTHROPIC_API_KEY=
# Strong model — Claude Opus 4.7 for PM synthesis, critic, complex reasoning
ANTHROPIC_STRONG_MODEL=claude-opus-4-7
# Cheap model — Claude Haiku 4.5 for extraction, summarization, classification
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
# Critic agent (cross-family bias intentional).
ANTHROPIC_CRITIC_MODEL=claude-opus-4-7

# Gemini (Google GenAI) — news, social, long-doc analysts (Phase 4).
GEMINI_API_KEY=
GEMINI_NEWS_MODEL=gemini-2.5-flash
GEMINI_SOCIAL_MODEL=gemini-2.5-flash
GEMINI_LONGDOC_MODEL=gemini-3.1-pro

# -----------------------------------------------------------------------------
# DATABASE
# Default = SQLite (zero-config local). Postgres recommended for production.
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./marketmosaic.db
POSTGRES_USER=marketmosaic
POSTGRES_PASSWORD=marketmosaic
POSTGRES_DB=marketmosaic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# USE_DEMO_DATA=true forces demo mode even if live keys are present.
# ENABLE_LIVE_DATA=true allows providers to attempt live fetches (with fallback).
# ENABLE_AGENT_CRITIC enables the risk-committee critic loop.
# ENABLE_VECTOR_SEARCH uses embeddings (requires OPENAI_API_KEY); else BM25.
# -----------------------------------------------------------------------------
USE_DEMO_DATA=true
ENABLE_LIVE_DATA=false
ENABLE_AGENT_CRITIC=true
ENABLE_VECTOR_SEARCH=false
# Route single_stock_analysis through the OpenAI Agents SDK runtime when set.
# Default false keeps the deterministic legacy graph in charge.
USE_AGENTS_SDK=false
# Always-on monitoring loops (EDGAR/news/social/macro). Default false in dev.
ENABLE_MONITORING=false

# -----------------------------------------------------------------------------
# MARKET DATA & FUNDAMENTALS PROVIDERS (all optional)
# Each provider has a free tier that MarketMosaic supports. Leave blank to
# stay in demo mode.
# -----------------------------------------------------------------------------
# Financial Modeling Prep — fundamentals, profiles, ratios
FMP_API_KEY=
# Alpha Vantage — earnings transcripts, news/sentiment
ALPHA_VANTAGE_API_KEY=
# FRED — macro time series
FRED_API_KEY=
# Polygon — prices, news (optional)
POLYGON_API_KEY=
# Tiingo — prices, news (optional)
TIINGO_API_KEY=
# Finnhub — alt fundamentals/news (optional)
FINNHUB_API_KEY=
# Intrinio (optional)
INTRINIO_API_KEY=
# Nasdaq Data Link / Quandl (optional)
NASDAQ_DATA_LINK_API_KEY=

# SEC EDGAR requires a User-Agent for compliance. No API key.
SEC_USER_AGENT=MarketMosaic your-email@example.com

# -----------------------------------------------------------------------------
# APP / SERVER
# -----------------------------------------------------------------------------
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# RUNTIME LIMITS / TUNING
# -----------------------------------------------------------------------------
CACHE_TTL_SECONDS=3600
MAX_AGENT_CONTEXT_CHARS=60000
MAX_STOCKS_IN_PORTFOLIO=25
DEFAULT_STOCK_UNIVERSE=large_cap_demo
